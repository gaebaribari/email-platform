# --- Brevo (이메일 발송 + 데이터 저장소) ---
# https://app.brevo.com/settings/keys/api 에서 발급
BREVO_API_KEY=

# Brevo에 등록된 검증 완료된 sender (도메인 인증 안 했으면 Brevo가 인증해주는 sender 이메일 사용)
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=뉴스레터

# 신규 리스트가 들어갈 폴더. 비워두면 "newsletter" 폴더를 자동 생성/재사용한다.
# BREVO_FOLDER_ID=
# BREVO_FOLDER_NAME=newsletter

# --- 더블옵트인 JWT 서명키 ---
# openssl rand -base64 48 등으로 충분히 긴 랜덤 문자열을 사용
JWT_SECRET=

# 메일 안의 인증 링크 도메인 (배포 도메인으로 교체)
APP_BASE_URL=http://localhost:3000

# --- 데모 모드 ---
# true 로 두면 데이터 저장소로 Brevo 대신 브라우저 localStorage를 쓴다.
#  - 방문자별 격리(자기 브라우저에만 저장) → 공개 데모에서 실계정 오염 0
#  - 빈 상태로 시작 → 샘플/CSV로 추가하면 그 브라우저의 구독자 목록이 찬다
# NEXT_PUBLIC_ 접두사라 클라이언트·서버 양쪽에서 읽힌다.
# 로컬/실운영에선 비워두면(=false) 실제 Brevo로 동작한다.
NEXT_PUBLIC_DEMO_MODE=
